// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum Role {
  ADMIN    // Только управление пользователями
  MANAGER  // Работа со всеми проектами
  USER     // Партнер: видит только свои проекты
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  REVISION
  CLOSED
}

model Company {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  unp        String   @unique
  externalId String?  @unique
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
  @@index([unp])
}



model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  password           String
  name               String?
  companyName        String?
  unp                String?   @unique
  role               Role      @default(USER)
  mustChangePassword Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastSeen           DateTime  @default(now())
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  phone               String?  @unique @db.VarChar(20) 

  // 🔐 ПОЛЕ ДЛЯ КОНТРОЛЯ СЕССИЙ
  currentSessionId   String?   @db.VarChar(36) // UUID v4
  isBlocked          Boolean   @default(false)

   // --- Поля для защиты от брутфорса входа ---
  failedLoginAttempts Int      @default(0)
  lockUntil           DateTime? 

  // 🔥 НОВЫЕ ПОЛЯ ДЛЯ 2FA ---
  // Флаг: успешно ли пройден 2FA в текущей сессии
  twoFactorVerified   Boolean  @default(false)
  
  // Счетчик неудачных попыток ввода 2FA кода
  twoFactorAttempts   Int      @default(0)
  
  // Время блокировки после 3 неудачных попыток 2FA
  twoFactorLockUntil  DateTime?
  
  // Время последней отправки кода (для лимита 1 раз в 60 сек)
  twoFactorCodeSentAt DateTime? 

  // Связи
  projects           Project[] @relation("PartnerProjects")
  processedProjects  Project[] @relation("ManagerAction")
  messages           Message[]
  refreshTokens      RefreshToken[]
}

model RefreshToken {
  id              Int       @id @default(autoincrement())
  tokenHash       String    @unique @db.VarChar(64)      // SHA-256 хеш refresh токена
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String?   @db.VarChar(36)               // UUID сессии
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?
  replacedByHash  String?   @db.VarChar(64)               // ссылка на новый токен при ротации

  @@index([userId])
  @@index([sessionId])
}

model Project {
  id             Int           @id @default(autoincrement())
  number         String?       @unique 
  status         ProjectStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  formType       String

  // ПАРТНЕР: Cascade. Если удаляем партнера — его проекты удаляются автоматически.
  partnerId      Int
  partner        User          @relation("PartnerProjects", fields: [partnerId], references: [id], onDelete: Cascade)

  // МЕНЕДЖЕР: SetNull. Если менеджер удален — проект остается, но поле редактора очищается.
  lastEditorId   Int?
  lastEditor     User?         @relation("ManagerAction", fields: [lastEditorId], references: [id], onDelete: SetNull)

  customerName   String        
  customerInn    String        
  purchaseMethod String?       
  executionDate  DateTime?     
  dynamicData    Json

  // СООБЩЕНИЯ: Cascade. Удаление проекта удаляет весь его чат.
  messages       Message[]

  @@index([partnerId])
  @@index([customerInn])
  @@index([status])
}

model Message {
  id         Int      @id @default(autoincrement())
  text       String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
  
  // ПРОЕКТ: Cascade. Сообщения привязаны к жизни проекта.
  projectId  Int
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // АВТОР: Cascade. Если удаляем юзера — его сообщения удаляются.
  senderId   Int
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}